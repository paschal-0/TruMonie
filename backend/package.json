{
  "name": "trumonie-backend",
  "version": "0.1.0",
  "description": "Fintech backend (NestJS + Postgres + Redis) for TruMonie",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:debug": "node --inspect-brk -r ts-node/register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typeorm:migration:run": "ts-node ./node_modules/typeorm/cli.js -d ./typeorm.config.ts migration:run",
    "typeorm:migration:show": "ts-node ./node_modules/typeorm/cli.js -d ./typeorm.config.ts migration:show",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "test": "jest --config jest.config.js",
    "qa:smoke:p0": "node ./scripts/qa/p0-smoke.mjs",
    "qa:smoke:notifications": "node ./scripts/qa/notifications-smoke.mjs",
    "qa:reconcile": "node ./scripts/qa/reconciliation-check.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.9.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.6.2",
    "@types/passport-jwt": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "detect-newline": "^3.1.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react-is": "^18.3.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
